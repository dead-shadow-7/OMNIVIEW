# ── Core LLM (primary) ──
GEMINI_API_KEY=your-gemini-api-key

# ── Google Custom Search (news + images) ──
GOOGLE_API_KEY=your-google-api-key
GOOGLE_CX=your-custom-search-engine-id

# ── LLM fallbacks (cascaded in this order) ──
DEEPSEEK_API_KEY=your-deepseek-api-key
GROQ_API_KEY=your-groq-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Hugging Face (BLIP captioning, inference API) ──
HUGGINGFACE_API_KEY=your-huggingface-api-key

# ── News fallback ──
NEWS_API_KEY=your-newsapi-key

# ── OpenSky Network (aircraft tracking, optional — higher rate limits if set) ──
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# ── Social media collector (nlp_socilmedia.py CLI, optional) ──
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
